# Server configuration
PORT=3000

# Admin token: required to access protected admin endpoints
# (GET/PATCH/DELETE /api/orders, GET /api/contact)
# Generate a strong token for production: `openssl rand -hex 32`
ADMIN_TOKEN=change-me-in-production

# Tax rate applied to orders (e.g. 0.08 = 8%)
TAX_RATE=0.08

# Currency symbol shown in receipts
CURRENCY=USD
